# MySQL (Railway auto-provides these when you add a MySQL plugin)
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLDATABASE=rgba
MYSQLUSER=root
MYSQLPASSWORD=root123

# JWT - change this to a long random string in production
JWT_SECRET=your-very-long-random-secret-here

# Frontend URL for CORS (set to your Vercel URL after deploy)
FRONTEND_URL=https://your-app.vercel.app
